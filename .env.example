# OllieProxy — exemplo de configuração
#
# Copie para `.env` e ajuste conforme necessário. As variáveis são lidas pelo
# proxy em src/config.ts. Valores omitidos usam os defaults comentados abaixo.

# --- Servidor ---
# Porta de escuta (default: 3000)
PORT=3000
# Host de escuta (default: 0.0.0.0)
HOST=0.0.0.0

# --- Upstream ---
# URL base do backend OllieChat (default: https://olliechat-lac.vercel.app/)
UPSTREAM_URL=https://olliechat-lac.vercel.app/
# Timeout da requisição ao upstream, em milissegundos (default: 120000)
UPSTREAM_TIMEOUT_MS=120000
# Limite de corpo da requisição, em bytes (default: 4194304 = 4 MiB)
BODY_LIMIT_BYTES=4194304

# --- Layer 1: redação reversível de PII ---
# Ativa a redação de dados identificáveis/segredos nas mensagens de entrada
# antes de chegar ao upstream, com restauração automática na resposta.
# Ativo por padrão. Use 0/false/off para desativar completamente.
REDACT_PII=1

# Categorias a redar quando REDACT_PII=1. Omitir usa o conjunto padrão
# (sensíveis + baixo falso-positivo). Use `all` para incluir as opt-in de FP
# mais alto, ou liste explicitamente.
#
# Padrão:      email,phone,cpf,cnpj,apikey,card,dburl,jwt,privatekey,aws
# Opt-in:      ip,mac,cep,pis,ssn,token
# Tudo:        all
#
# Exemplos:
#   REDACT_CATEGORIES=all
#   REDACT_CATEGORIES=email,phone,dburl,jwt
REDACT_CATEGORIES=email,phone,cpf,cnpj,apikey,card,dburl,jwt,privatekey,aws

# --- API keys + rate limit ---
# Liga a exigência de API key em /v1/* (health continua liberado). OFF por
# padrão: crie chaves com `npm run key:create` antes de ligar.
AUTH_ENABLED=0
# Arquivo onde as chaves (hasheadas) são guardadas.
KEYS_FILE=./data/keys.json
# Limite padrão de requisições por minuto por chave. Cada chave pode sobrescrever
# via --rpm ao ser criada.
DEFAULT_RPM=60

# --- Modelos dinâmicos ---
# TTL do cache da lista de modelos do upstream, em milissegundos (default: 300000 = 5 min)
MODELS_CACHE_TTL_MS=300000
